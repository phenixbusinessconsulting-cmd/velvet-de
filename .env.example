# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/velvet_de"

# ─── Auth JWT secrets (generate with: openssl rand -base64 64) ─
JWT_SECRET="CHANGE_THIS_TO_A_RANDOM_64_CHAR_SECRET"
JWT_REFRESH_SECRET="CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_SECRET"

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="VELVET"

# ─── File storage (e.g. AWS S3 or Supabase Storage) ──────────
STORAGE_BUCKET_NAME="velvet-photos"
STORAGE_ENDPOINT="https://your-storage-endpoint.com"
STORAGE_ACCESS_KEY="your-access-key"
STORAGE_SECRET_KEY="your-secret-key"
STORAGE_CDN_URL="https://cdn.velvet-companions.de"

# ─── Email (transactional, e.g. Resend or Postmark) ──────────
EMAIL_FROM="noreply@velvet-companions.de"
RESEND_API_KEY="re_xxx"

# ─── Encryption key for KYC documents (AES-256) ──────────────
# LEGAL NOTE (DE): Document encryption required under DSGVO Art. 32
ENCRYPTION_KEY="CHANGE_THIS_TO_A_RANDOM_32_BYTE_HEX_KEY"

# ─── Rate limiting (optional Redis) ──────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Admin ───────────────────────────────────────────────────
ADMIN_INITIAL_EMAIL="admin@velvet-companions.de"
ADMIN_INITIAL_PASSWORD="CHANGE_THIS_BEFORE_DEPLOY"

# ─── Analytics (optional) ────────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="velvet-companions.de"
