generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════
//  AUTH & USERS
// ════════════════════════════════════════════════════════════

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  passwordHash      String?
  role              UserRole  @default(VISITOR)

  // Account status
  isBlocked         Boolean   @default(false)
  blockReason       String?
  blockedAt         DateTime?
  blockedBy         String?

  // Age verification
  // LEGAL NOTE (DE): Jugendschutzgesetz §4 — age verification required
  ageVerified       Boolean   @default(false)
  ageVerifiedAt     DateTime?
  ageVerificationIp String?

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?
  lastLoginIp       String?

  // Relations
  professionalProfile ProfessionalProfile?
  sessions            Session[]
  favorites           Favorite[]
  reports             Report[]             @relation("ReportedBy")
  consentLogs         ConsentLog[]
  auditLogs           AuditLog[]

  @@index([email])
  @@index([role])
}

enum UserRole {
  VISITOR
  PROFESSIONAL
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ════════════════════════════════════════════════════════════
//  PROFESSIONAL PROFILES
// ════════════════════════════════════════════════════════════

model ProfessionalProfile {
  id     String        @id @default(cuid())
  userId String        @unique
  status ProfileStatus @default(DRAFT)

  // Public display info
  displayName   String         @db.VarChar(60)
  age           Int            // Never store DOB publicly
  cityId        String
  districtName  String?        @db.VarChar(100)
  tagline       String?        @db.VarChar(120)
  bio           String?        @db.Text
  type          ProfessionalType @default(INDEPENDENT)
  agencyName    String?

  // Physical characteristics
  heightCm      Int?           // e.g. 170
  weightKg      Int?           // e.g. 57
  bustCm        Int?           // e.g. 95
  waistCm       Int?           // e.g. 64
  hipCm         Int?           // e.g. 92
  cupSize       String?        @db.VarChar(4) // e.g. "C", "D", "DD"

  // Attributes (moderated tags only — no explicit service descriptions)
  // LEGAL NOTE (DE): Service descriptions must comply with applicable law
  servicesTags  String[]
  languages     String[]       // ISO codes e.g. ["de","en","fr"]

  // Availability & logistics
  outcall       Boolean        @default(false)
  incall        Boolean        @default(false)
  travel        Boolean        @default(false)
  availDays     Int[]          // 0=Mon ... 6=Sun

  // Banner (wide format, 16:9, for profile hero)
  bannerUrl         String?
  bannerStoragePath String?

  // Statistics
  viewCount     Int            @default(0)
  favoriteCount Int            @default(0)

  // Verification
  // LEGAL NOTE (DE): ProstSchG §3 — mandatory registration verification
  kycStatus     KYCStatus      @default(PENDING)
  kycNotes      String?
  verifiedAt    DateTime?
  verifiedBy    String?

  // Admin workflow
  rejectedReason  String?
  suspendedReason String?
  adminNote       String?
  lastReviewedAt  DateTime?
  lastReviewedBy  String?

  // SEO
  slug            String        @unique
  metaTitle       String?       @db.VarChar(60)
  metaDescription String?       @db.VarChar(160)

  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?

  // Private gallery monetisation
  privateGalleryPrice Decimal?   @db.Decimal(10,2) // null = not for sale

  // Relations
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  city                  City          @relation(fields: [cityId], references: [id])
  photos                Photo[]
  videos                Video[]
  kycDocuments          KYCDocument[]
  reviews               Review[]
  favorites             Favorite[]
  reports               Report[]      @relation("ProfileReports")
  availability          Availability[]
  privateGalleryAccess  PrivateGalleryAccess[]

  @@index([cityId])
  @@index([status])
  @@index([slug])
  @@index([kycStatus])
}

enum ProfileStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  SUSPENDED
  REJECTED
  ARCHIVED
}

enum ProfessionalType {
  INDEPENDENT
  AGENCY
}

enum KYCStatus {
  PENDING
  DOCUMENTS_REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

// ════════════════════════════════════════════════════════════
//  KYC / DOCUMENT VERIFICATION
//  LEGAL NOTE (DE): Comply with ProstSchG + DSGVO Art. 5
//  — Documents must be securely encrypted at rest
//  — Retention policy must be defined with legal counsel
//  — Access must be logged (see AuditLog)
// ════════════════════════════════════════════════════════════

model KYCDocument {
  id        String      @id @default(cuid())
  profileId String

  docType   KYCDocType
  // Path to AES-256 encrypted file in secure storage (never public CDN)
  // LEGAL NOTE: Encryption key management must follow DSGVO Art. 32
  encPath   String

  status    KYCStatus   @default(PENDING)
  notes     String?
  reviewedAt DateTime?
  reviewedBy String?

  submittedAt DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  profile   ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([docType])
}

enum KYCDocType {
  GOVERNMENT_ID         // Passport / Ausweis
  PROOF_OF_AGE          // Secondary age proof
  PROST_SCHG_REG        // ProstSchG registration certificate (DE mandatory)
  BUSINESS_REG          // Gewerbeanmeldung (for agencies)
  HEALTH_CERTIFICATE    // Gesundheitszeugnis (if required)
}

// ════════════════════════════════════════════════════════════
//  PHOTOS
// ════════════════════════════════════════════════════════════

model Photo {
  id          String   @id @default(cuid())
  profileId   String
  cdnUrl      String   // Public CDN URL (approved only)
  storagePath String   // Internal storage path
  isMain      Boolean  @default(false)
  isPrivate   Boolean  @default(false) // Premium/unlockable photos
  position    Int      @default(0)

  // Moderation
  isApproved  Boolean  @default(false)
  isFlagged   Boolean  @default(false)
  flagReason  String?
  moderatedAt DateTime?
  moderatedBy String?

  createdAt   DateTime @default(now())

  profile     ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([isApproved])
}

// ════════════════════════════════════════════════════════════
//  VIDEOS
// ════════════════════════════════════════════════════════════

model Video {
  id          String   @id @default(cuid())
  profileId   String
  cdnUrl      String
  storagePath String
  position    Int      @default(0)
  isApproved  Boolean  @default(false)
  isPrivate   Boolean  @default(false)
  moderatedAt DateTime?
  moderatedBy String?
  createdAt   DateTime @default(now())

  profile     ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([isApproved])
}

// ════════════════════════════════════════════════════════════
//  PRIVATE GALLERY ACCESS
// ════════════════════════════════════════════════════════════

model PrivateGalleryAccess {
  id        String   @id @default(cuid())
  profileId String
  email     String
  token     String   @unique @default(cuid())
  amount    Decimal  @db.Decimal(10,2)
  status    String   @default("SIMULATED") // SIMULATED | PAID | EXPIRED
  createdAt DateTime @default(now())

  profile   ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([token])
  @@index([email])
}

// ════════════════════════════════════════════════════════════
//  AVAILABILITY
// ════════════════════════════════════════════════════════════

model Availability {
  id        String   @id @default(cuid())
  profileId String
  dayOfWeek Int      // 0=Mon, 6=Sun
  startTime String   // "HH:mm"
  endTime   String   // "HH:mm"

  profile   ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

// ════════════════════════════════════════════════════════════
//  REVIEWS
// ════════════════════════════════════════════════════════════

model Review {
  id        String       @id @default(cuid())
  profileId String
  rating    Int          // 1–5

  // Anonymous text review — moderated before display
  comment   String?      @db.Text

  // Moderation
  status    ReviewStatus @default(PENDING)
  isFlagged Boolean      @default(false)
  flagReason String?
  moderatedAt DateTime?
  moderatedBy String?

  // Anti-spam: hash of IP+UA — not stored plaintext (DSGVO)
  sessionHash String?

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  profile   ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([status])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

// ════════════════════════════════════════════════════════════
//  FAVORITES
// ════════════════════════════════════════════════════════════

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  profileId String
  createdAt DateTime @default(now())

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([userId])
}

// ════════════════════════════════════════════════════════════
//  REPORTS / SIGNALEMENT
// ════════════════════════════════════════════════════════════

model Report {
  id          String       @id @default(cuid())
  profileId   String
  reportedBy  String
  reason      ReportReason
  description String?      @db.Text
  status      ReportStatus @default(OPEN)
  priority    ReportPriority @default(NORMAL)
  resolvedAt  DateTime?
  resolvedBy  String?
  resolution  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  profile  ProfessionalProfile @relation("ProfileReports", fields: [profileId], references: [id])
  reporter User                @relation("ReportedBy", fields: [reportedBy], references: [id])

  @@index([profileId])
  @@index([status])
  @@index([priority])
}

enum ReportReason {
  FAKE_PROFILE
  MINOR_SUSPECTED       // Highest priority — immediate suspension
  UNDERAGE_CONTENT
  FRAUD
  SPAM
  ILLEGAL_CONTENT
  HARASSMENT
  INCORRECT_INFORMATION
  OTHER
}

enum ReportStatus {
  OPEN
  INVESTIGATING
  ESCALATED
  RESOLVED
  DISMISSED
}

enum ReportPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL              // e.g. suspected minor — auto-escalate
}

// ════════════════════════════════════════════════════════════
//  BLOCKED WORDS / CONTENT MODERATION
// ════════════════════════════════════════════════════════════

model BlockedWord {
  id        String   @id @default(cuid())
  word      String   @unique
  severity  Int      @default(1) // 1=warn, 2=block, 3=flag for review
  addedBy   String?
  createdAt DateTime @default(now())
}

// ════════════════════════════════════════════════════════════
//  GEOGRAPHY
// ════════════════════════════════════════════════════════════

model Country {
  id        String  @id @default(cuid())
  code      String  @unique // ISO 3166-1 alpha-2, e.g. "DE", "AT", "CH"
  nameDE    String
  nameEN    String
  slug      String  @unique
  flag      String? // emoji drapeau, ex: "🇩🇪"
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  cities City[]
}

model City {
  id            String   @id @default(cuid())
  nameDE        String
  nameEN        String
  slug          String   @unique
  state         String   // Bundesland
  stateCode     String   // e.g. "BE", "BY", "HH"
  isActive      Boolean  @default(true)
  showOnLanding Boolean  @default(false)
  sortOrder     Int      @default(0)
  profileCount  Int      @default(0)
  taglineDE     String?  @db.VarChar(120)
  taglineFR     String?  @db.VarChar(120)

  countryId    String?
  country      Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

  profiles     ProfessionalProfile[]

  @@index([countryId])
}

// ════════════════════════════════════════════════════════════
//  DSGVO / CONSENT
//  LEGAL NOTE (DE): DSGVO Art. 7 — consent must be documented
// ════════════════════════════════════════════════════════════

model ConsentLog {
  id          String      @id @default(cuid())
  userId      String?
  sessionId   String?

  consentType ConsentType
  granted     Boolean
  version     String      // Consent document version date
  language    String      @default("de") // ISO language

  ipHash      String?     // SHA-256 hashed — not plaintext (DSGVO)
  userAgent   String?

  grantedAt   DateTime    @default(now())
  revokedAt   DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([consentType])
  @@index([grantedAt])
}

enum ConsentType {
  COOKIES_ESSENTIAL
  COOKIES_ANALYTICS
  COOKIES_MARKETING
  AGE_VERIFICATION
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  DATA_PROCESSING
}

// ════════════════════════════════════════════════════════════
//  SECURITY AUDIT LOG
//  LEGAL NOTE (DE): DSGVO Art. 30 — records of processing activities
// ════════════════════════════════════════════════════════════

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    AuditAction
  entity    String?
  entityId  String?
  oldValue  Json?
  newValue  Json?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum AuditAction {
  USER_REGISTER
  USER_LOGIN
  USER_LOGIN_FAILED
  USER_LOGOUT
  USER_BLOCKED
  USER_DELETED
  AGE_VERIFIED
  PROFILE_CREATED
  PROFILE_UPDATED
  PROFILE_SUBMITTED
  PROFILE_APPROVED
  PROFILE_REJECTED
  PROFILE_SUSPENDED
  PHOTO_UPLOADED
  PHOTO_APPROVED
  PHOTO_REJECTED
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  REVIEW_CREATED
  REVIEW_APPROVED
  REVIEW_REJECTED
  REPORT_CREATED
  REPORT_RESOLVED
  ADMIN_ACTION
  DATA_EXPORT_REQUEST // DSGVO Art. 20
  DATA_DELETE_REQUEST // DSGVO Art. 17
}

// ════════════════════════════════════════════════════════════
//  RATE LIMITING
// ════════════════════════════════════════════════════════════

model RateLimit {
  id         String    @id @default(cuid())
  identifier String    // Hashed IP or user ID
  action     String    // e.g. "login", "register", "contact"
  attempts   Int       @default(1)
  resetAt    DateTime
  blockedAt  DateTime?

  @@unique([identifier, action])
  @@index([identifier])
  @@index([resetAt])
}

// ════════════════════════════════════════════════════════════
//  LEGAL PAGES (editable from admin)
// ════════════════════════════════════════════════════════════

model LegalPage {
  id        String   @id @default(cuid())
  slug      String   @unique  // "impressum" | "agb" | "datenschutz"
  titleDE   String   @default("")
  titleFR   String   @default("")
  contentDE String   @default("") @db.Text
  contentFR String   @default("") @db.Text
  updatedAt DateTime @updatedAt
}
